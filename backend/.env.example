# ─── Django ───────────────────────────────────────────────────
DJANGO_SECRET_KEY=your-very-secret-key-change-this
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── Database ─────────────────────────────────────────────────
# Leave DB_NAME empty to use SQLite (no setup required).
# Set DB_NAME to use MySQL:
DB_NAME=
DB_USER=root
DB_PASSWORD=
DB_HOST=127.0.0.1
DB_PORT=3306

# ─── CORS ─────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_ALL=False

# ─── AI / LLM ─────────────────────────────────────────────────
# Option A — LM Studio (local, free):
#   1. Open LM Studio, download a model (e.g. Mistral 7B, Llama 3)
#   2. Start the local server (it runs on port 1234 by default)
#   3. Set OPENAI_BASE_URL=http://localhost:1234/v1
#   4. OPENAI_API_KEY can be anything (LM Studio ignores it)
#   5. Set OPENAI_MODEL to the model identifier shown in LM Studio
OPENAI_API_KEY=lm-studio
OPENAI_BASE_URL=http://localhost:1234/v1
OPENAI_MODEL=local-model

# Option B — OpenAI Cloud:
#   OPENAI_API_KEY=sk-...
#   OPENAI_BASE_URL=
#   OPENAI_MODEL=gpt-4o-mini

# ─── ChromaDB ─────────────────────────────────────────────────
# Directory where vector embeddings are persisted on disk.
CHROMA_PERSIST_DIR=./chroma_db

# ─── Embeddings ───────────────────────────────────────────────
# Sentence-Transformers model for generating embeddings locally.
EMBEDDING_MODEL=all-MiniLM-L6-v2
